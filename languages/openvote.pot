#: admin/partials/manual.php:56
#, php-format
msgid ""
"%s to wtyczka WordPress służąca do przeprowadzania elektronicznych głosowań "
"wśród zarejestrowanych użytkowników witryny. Umożliwia tworzenie głosowań "
