#: admin/partials/manual.php:56
#, php-format
msgid ""
"%s to wtyczka WordPress służąca do przeprowadzania elektronicznych głosowań "
"wśród zarejestrowanych użytkowników witryny. Umożliwia tworzenie głosowań "
"wielopytaniowych, definiowanie grup docelowych, wysyłkę zaproszeń e-mail "
"oraz prezentację wyników — w formie zbiorczej lub jawnej."
msgstr "%s is a WordPress plugin for running electronic votes among registered site users. It allows creating multi-question polls, defining target groups, sending email invitations and displaying results — in aggregate or public form."

#: admin/partials/manual.php:60
msgid "Główne elementy systemu"
msgstr "Main system components"

#: admin/partials/manual.php:62
msgid "zestaw pytań z określonym czasem trwania i grupą docelową."
msgstr "set of questions with a defined duration and target group."

#: admin/partials/manual.php:63 admin/partials/manual.php:220
msgid "Pytania i odpowiedzi"
msgstr "Questions and answers"

#: admin/partials/manual.php:63
msgid ""
"każde głosowanie zawiera 1–24 pytania, każde pytanie ma 3–12 odpowiedzi. "
"Ostatnia odpowiedź to zawsze \"Wstrzymuję się\"."
msgstr ""

#: admin/partials/manual.php:64
msgid ""
"zbiory użytkowników (np. według miasta). Głosowanie może być skierowane do "
"jednej lub wielu grup."
msgstr "collections of users (e.g. by city). A poll can target one or more groups."

#: admin/partials/manual.php:65
msgid ""
"użytkownicy z uprawnieniami do zarządzania głosowaniami przypisanymi do "
"konkretnych grup."
msgstr "users with permission to manage polls assigned to specific groups."

#: admin/partials/manual.php:66
msgid "Strona głosowania"
msgstr "Voting page"

#: admin/partials/manual.php:66
msgid ""
"publiczna strona WordPress z blokiem głosowania, dostępna pod adresem "
"skonfigurowanym w Konfiguracji."
msgstr "public WordPress page with the voting block, available at the URL set in Configuration."

#: admin/partials/manual.php:69
msgid "Przepływ pracy"
msgstr "Workflow"

#: admin/partials/manual.php:71
msgid "Administrator tworzy grupy i przypisuje do nich użytkowników."
msgstr "Administrator creates groups and assigns users to them."

#: admin/partials/manual.php:72
msgid ""
"Administrator (lub Koordynator) tworzy głosowanie, wybiera grupy docelowe i "
"pyta."
msgstr "Administrator (or Coordinator) creates a poll, selects target groups and questions."

#: admin/partials/manual.php:73
msgid ""
"Kliknięcie \"Wystartuj głosowanie\" zmienia status na Rozpoczęte i wysyła "
"zaproszenia e-mail."
msgstr ""

