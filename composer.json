{
    "name": "ep-rwl/openvote",
    "description": "Open Vote — system e-głosowania (ankiety i głosowania)",
    "authors": [
        {
            "name": "Tomasz Kalinowski",
            "email": "t7jk@protonmail.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "tecnickcom/tcpdf": "^6.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "brain/monkey": "^2.6",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "classmap": [
            "src/includes/",
            "src/admin/",
            "src/models/",
            "src/rest-api/"
        ]
    },
    "autoload-dev": {
        "classmap": [
            "tests/Unit/",
            "tests/Integration/"
        ]
    },
    "scripts": {
        "test": "phpunit --testsuite unit --bootstrap tests/bootstrap-unit.php",
        "test:integration": "phpunit --testsuite integration --bootstrap tests/bootstrap-integration.php"
    },
    "config": {
        "optimize-autoloader": true
    }
}
